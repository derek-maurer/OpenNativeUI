{
  "extends": "../../tsconfig.base.json",
  "include": ["src/renderer/**/*"],
  "compilerOptions": {
    "composite": true,
    "outDir": "out/renderer",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@opennative/shared": ["../shared/src/index.ts"]
    }
  }
}
