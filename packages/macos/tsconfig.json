{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": ".",
    "types": [],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@opennative/shared": [
        "../shared/src/index.ts"
      ],
      "@opennative/shared/*": [
        "../shared/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "**/node_modules",
    "**/Pods",
    "macos/build"
  ]
}