{
  "name": "opennativeui-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "mobile:ios": "npm run ios --workspace=@opennative/mobile",
    "mobile:android": "npm run android --workspace=@opennative/mobile",
    "mobile:start": "npm run start --workspace=@opennative/mobile",
    "macos:start": "npm run start --workspace=@opennative/macos",
    "macos:run": "npm run macos:start --workspace=@opennative/macos & npm run macos-no-packager --workspace=@opennative/macos",
    "macos:podinstall": "cd packages/macos/macos && bundle exec pod install",
    "shared:typecheck": "npm run typecheck --workspace=@opennative/shared",
    "mobile:typecheck": "npm run typecheck --workspace=@opennative/mobile",
    "macos:typecheck": "npm run typecheck --workspace=@opennative/macos",
    "typecheck": "npm run shared:typecheck && npm run mobile:typecheck && npm run macos:typecheck"
  },
  "devDependencies": {},
  "overrides": {
    "react": "19.1.4",
    "react-native": "0.81.6",
    "react-native-safe-area-context": "5.7.0"
  }
}
